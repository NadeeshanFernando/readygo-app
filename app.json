{
  "expo": {
    "name": "ReadyGo",
    "slug": "readygo",
    "scheme": "readygo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "ReadyGo needs camera access to scan ReadyGo tag QR codes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1220"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.readygo.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "ReadyGo scans nearby BLE tags to check your packed items.",
        "NSBluetoothPeripheralUsageDescription": "ReadyGo scans nearby BLE tags to check your packed items.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.readygo.app",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "CAMERA",
        "android.permission.CAMERA"
      ]
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bde9cae9-801c-4684-84d0-46a5bb53bfb6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bde9cae9-801c-4684-84d0-46a5bb53bfb6"
    }
  }
}
