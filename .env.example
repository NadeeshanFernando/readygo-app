# Copy this file to .env in the project root.
# Expo automatically inlines any variable prefixed with EXPO_PUBLIC_ into the
# app bundle at build time — no extra config needed (SDK 49+).
#
# NOTE: anything here ends up inside the app bundle and is NOT secret.
# This should only ever be a public server URL, never a signing key.

# URL of your tag-auth-backend-example (or your own equivalent) deployment.
# If left unset, the app falls back to an INSECURE local dev check so you
# can keep developing before the backend exists — never ship a build with
# this unset.
EXPO_PUBLIC_TAG_AUTH_API_URL=http://localhost:3000
